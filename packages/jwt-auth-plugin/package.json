  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrey-aka-skif/draft-jwt-auth-plugin.git",
    "directory": "packages/jwt-auth-plugin"
  },
  "bugs": {
    "url": "https://github.com/andrey-aka-skif/draft-jwt-auth-plugin/issues"
