{
  "JwtSettings": {
    "Secret": "YourSuperSecretKeyMustBeAtLeast32Chars!",
    "Issuer": "vue-frontend",
    "Audience": "vue-frontend-clients",
    "AccessTokenLifetimeSeconds": 60,
    "RefreshTokenLifetimeMinutes": 2
  },
  "CorsSettings": {
    "PolicyName": "VueClient",
    "Origins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ],
    "AllowAnyHeader": true,
    "AllowAnyMethod": true,
    "AllowCredentials": true
  },
  "AllowedHosts": "*"
}
